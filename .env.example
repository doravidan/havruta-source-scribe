# Public Supabase client config
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# AI companion: OpenRouter direct, no Lovable AI Gateway credits.
# Create a key at https://openrouter.ai/keys and add it as a Lovable secret.
OPENROUTER_API_KEY=
# Defaults to OpenRouter's free model router. You can pin a specific free model if needed,
# for example: meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CHAT_MODEL=openrouter/free

# Optional: direct Gemini embeddings if you want vector search/ingestion without Lovable.
# Leave empty to use source keyword fallback for asks and skip embeddings during ingest.
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-001

# Optional: improves OpenRouter attribution headers.
APP_PUBLIC_URL=
